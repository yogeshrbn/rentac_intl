                          <CellContents>
                            <Textbox Name="Textbox70">
                              <CanGrow>true</CanGrow>
                              <KeepTogether>true</KeepTogether>
                              <Paragraphs>
                                <Paragraph>
                                  <TextRuns>
                                    <TextRun>
                                      <Value>Subject to Gurgaon Juridiction Only.</Value>
                                      <Style>
                                        <FontFamily>Calibri</FontFamily>
                                        <FontSize>9pt</FontSize>
                                      </Style>
                                    </TextRun>
                                  </TextRuns>
                                  <ListStyle>Numbered</ListStyle>
                                  <ListLevel>1</ListLevel>
                                  <Style />
                                </Paragraph>
                                <Paragraph>
                                  <TextRuns>
                                    <TextRun>
                                      <Value>The full cost price of UNRETURNED MATERIAL will be charged along with its charges.</Value>
                                      <Style>
                                        <FontFamily>Calibri</FontFamily>
                                        <FontSize>9pt</FontSize>
                                      </Style>
                                    </TextRun>
                                  </TextRuns>
                                  <ListStyle>Numbered</ListStyle>
                                  <ListLevel>1</ListLevel>
                                  <Style />
                                </Paragraph>
                                <Paragraph>
                                  <TextRuns>
                                    <TextRun>
                                      <Value>Payment is to be made within 7 days on preparation of the bill or interest will be charged @ 24% p.a.</Value>
                                      <Style>
                                        <FontFamily>Calibri</FontFamily>
                                        <FontSize>9pt</FontSize>
                                      </Style>
                                    </TextRun>
                                  </TextRuns>
                                  <ListStyle>Numbered</ListStyle>
                                  <ListLevel>1</ListLevel>
                                  <Style />
                                </Paragraph>
                                <Paragraph>
                                  <TextRuns>
                                    <TextRun>
                                      <Value>This bill has been generated against the rent charges of the material and NOT SALE.</Value>
                                      <Style>
                                        <FontFamily>Calibri</FontFamily>
                                        <FontSize>9pt</FontSize>
                                      </Style>
                                    </TextRun>
                                  </TextRuns>
