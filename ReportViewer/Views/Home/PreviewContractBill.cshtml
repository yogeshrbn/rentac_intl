        <tr>
            <th class="table-cell" style="width:70mm;border-right:none;">Description</th>
            <th class="table-cell" style="width:30px;text-align:center;">Qty</th>
            <th class="table-cell text-center" style="width: 0.5in !important; border-left: none;">Area</th>
            <th class="table-cell" style="width:80px;">Total Area</th>
