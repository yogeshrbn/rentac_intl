@using ReportViewer.Helpers
@using System.Data

@functions
{
    private static bool ShowContractType16(DataRow header)
    {
        if (header == null || header.Table == null) return false;
        if (header.Table.Columns.Contains("QuotationType") && header["QuotationType"] != DBNull.Value)
            return Convert.ToInt16(header["QuotationType"]) == 16;
        if (header.Table.Columns.Contains("InvoiceType") && header["InvoiceType"] != DBNull.Value)
            return Convert.ToInt32(header["InvoiceType"]) == 5;
        return false;
    }

    private static decimal? GetLineArea(DataRow row)
    {
        if (row == null || row.Table == null) return null;
        if (row.Table.Columns.Contains("Area") && row["Area"] != DBNull.Value)
        {
            try { return Convert.ToDecimal(row["Area"]); } catch { return null; }
        }
        if (row.Table.Columns.Contains("Height") && row.Table.Columns.Contains("Width"))
        {
            try
            {
                var h = row["Height"] == DBNull.Value ? 0m : Convert.ToDecimal(row["Height"]);
                var w = row["Width"] == DBNull.Value ? 0m : Convert.ToDecimal(row["Width"]);
                var p = h * w;
                return p > 0 ? (decimal?)p : null;
            }
            catch { return null; }
        }
        return null;
    }

    private static decimal GetHeaderArea(DataRow header)
    {
        if (header == null || header.Table == null) return 0m;
        if (header.Table.Columns.Contains("ContractArea") && header["ContractArea"] != DBNull.Value)
        { try { return Convert.ToDecimal(header["ContractArea"]); } catch { } }
        if (header.Table.Columns.Contains("BillArea") && header["BillArea"] != DBNull.Value)
        { try { return Convert.ToDecimal(header["BillArea"]); } catch { } }
        if (header.Table.Columns.Contains("Area") && header["Area"] != DBNull.Value)
        { try { return Convert.ToDecimal(header["Area"]); } catch { } }
        return 0m;
    }

    private static string FormatTotalArea(DataRow row, DataRow header)
    {
        if (row == null) return "";
        decimal qty = 0m;
        try { qty = row["Quantity"] == DBNull.Value ? 0m : Convert.ToDecimal(row["Quantity"]); } catch { }
        var lineA = GetLineArea(row);
        if (lineA.HasValue && lineA.Value > 0m)
            return (qty * lineA.Value).ToString("N0");
        var headA = GetHeaderArea(header);
        if (headA > 0m)
            return (qty * headA).ToString("N0");
        return "";
    }

    private static string FormatLineAreaDisplay(DataRow row)
    {
        var a = GetLineArea(row);
        return a.HasValue && a.Value != 0m ? a.Value.ToString("N0") : "";
    }
}

@{
    Layout = null;
    var data = ViewBag.BillData;

    var imagepath = data.Tables[0].Rows[0]["CompanyLogo"];
    var signature = data.Tables[0].Rows[0]["Signature"];
    var firstRow = data.Tables[0].Rows[0];
    var taxes = data.Tables[1];
    //var charges = data.Tables[4];
    var IGST = data.Tables[0].Compute("Sum(IGST)", "");
    var CGST = data.Tables[0].Compute("Sum(CGST)", "");
    var SGST = data.Tables[0].Compute("Sum(SGST)", "");


    var subTotal = data.Tables[0].Compute("Sum(SubTotal)", "");
    var rowsToSpanAtBottom = 2;

    //if (data.Tables[1] != null)
    //{
    //    taxAmount = Convert.ToDecimal(data.Tables[1].Compute("Sum(TaxAmount)", ""));
    //}
    var total = subTotal + +IGST + CGST + SGST;

    var billingConfig = BillingConfigViewHelper.AsEnumerable(ViewBag.ConfigData);
    var invoiceTitle = "TAX INVOICE";// BillingConfigViewHelper.GetValue(billingConfig, "invoiceTitle", "TAX Invoice");
    var billPeriodText = BillingConfigViewHelper.GetValue(billingConfig, "billPeriodText", "Bill Period");
    var showCompanyPhoneMode = BillingConfigViewHelper.GetContactShowMode(billingConfig, "showCompanyPhone");
    var showCompanyEmailMode = BillingConfigViewHelper.GetContactShowMode(billingConfig, "showCompanyEmail");
    var showCompanyWebsiteMode = BillingConfigViewHelper.GetContactShowMode(billingConfig, "showCompanyWebsite");
    var showMSMENumberMode = BillingConfigViewHelper.GetContactShowMode(billingConfig, "showMSMENumber");
    var showClientMobileMode = BillingConfigViewHelper.GetContactShowMode(billingConfig, "showClientMobile");
    var showClientEmailMode = BillingConfigViewHelper.GetContactShowMode(billingConfig, "showClientEmail");
    var showClientPinMode = BillingConfigViewHelper.GetContactShowMode(billingConfig, "showClientPin");
    var showPONumberMode = BillingConfigViewHelper.GetContactShowMode(billingConfig, "showPONumber");
    var hideZeroAmountItem = BillingConfigViewHelper.GetBool(billingConfig, "hideZeroAmountItem", false);

    var showContractType16 = ShowContractType16(firstRow);
    var totalCols = 8;//
    var spanWords = totalCols - 3;
    var spanSingleLabel = totalCols - 1;

    var codeColHeader = Convert.ToString(ViewBag.contractbillcodetype) == "SACCode" ? "SAC" : "HSN";

    total += firstRow["Freight"] + firstRow["FreightTax"];
    if (firstRow["Freight"] > 0)
    {
        rowsToSpanAtBottom += 1;
    }
    if (firstRow["FreightTax"] > 0)
    {
        if (IGST == 0)
        {
            SGST += firstRow["FreightTax"] / 2;
            CGST += firstRow["FreightTax"] / 2;
        }
        else
        {
            IGST += firstRow["FreightTax"];
        }
    }
    if (firstRow["ChargesTax"] > 0)
    {
        if (IGST == 0)
        {
            SGST += firstRow["ChargesTax"] / 2;
            CGST += firstRow["ChargesTax"] / 2;

        }
        else
        {
            IGST += firstRow["ChargesTax"];
        }
    }

    //if (firstRow["ChargesTax"] > 0)
    //{
    //    if (IGST == 0)
    //    {
    //        SGST += firstRow["ChargesTax"] / 2;
    //        CGST += firstRow["ChargesTax"] / 2;

    //    }
    //    else
    //    {
    //        IGST += firstRow["ChargesTax"];
    //    }
    //}
    //if (charges != null && charges.Rows.Count > 0)
    //{
    //    total += charges.Compute("Sum(Amount)", "");
    //}
    //total -= firstRow["discount"];
    total = Math.Round(total, MidpointRounding.AwayFromZero);

    if (IGST > 0)
    {
        rowsToSpanAtBottom++;
    }
    if (CGST > 0)
    {
        rowsToSpanAtBottom++;
    }
    if (SGST > 0)
    {
        rowsToSpanAtBottom++;
    }
    if (firstRow["otherChargeAmount"] > 0)
    {
        rowsToSpanAtBottom += 1;
    }
    total = firstRow["Taxable"] + SGST + IGST + CGST;
}

