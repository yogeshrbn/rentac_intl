        </tr>
    </thead>
    <tbody class="table-body">

        @{
            foreach (var row in data.Tables[0].Rows)
            {
                if (hideZeroAmountItem && Convert.ToDecimal(row["SubTotal"]) == 0m)
                {
                    continue;
                }
                <tr class="table-row invoice-line-row">
