<script>
    (function () {
        function a4HeightPx() {
            return Math.round(297 * 96 / 25.4);
        }
        /** Use A4 printable height — window.innerHeight does not match printed page slices (causes missed totals thead). */
        function printablePageHeightPx() {
            var marginMm = 24;
            var marginPx = Math.round(marginMm * 96 / 25.4 * 2);
            return Math.max(400, a4HeightPx() - marginPx);
        }
        function docTop(el) {
            var r = el.getBoundingClientRect();
            return r.top + (window.pageYOffset || document.documentElement.scrollTop || 0);
        }
        /** True if parent thead intersects the same print-page band as the top of the totals wrap. */
        function parentHeaderOnTotalsPage(parentEl, totalsWrap, pageH) {
            if (!parentEl || !totalsWrap || pageH <= 0) return false;
            var totalsY = docTop(totalsWrap);
            var pageStart = Math.floor(totalsY / pageH) * pageH;
            var pageEnd = pageStart + pageH;
            var phTop = docTop(parentEl);
            var phBottom = phTop + parentEl.offsetHeight;
            return phBottom > pageStart && phTop < pageEnd;
        }
        /** Show #rent-bill-totals-table .totals-repeat-thead in print when #parentheadertable is not on that page. */
        function updateTotalsRepeatHeader() {
            var lineTable = document.getElementById('rent-bill-line-items-table');
            var totalsWrap = document.getElementById('rent-bill-totals-wrap');
            var totalsTable = document.getElementById('rent-bill-totals-table');
            var parentheadertable = document.getElementById('parentheadertable');

            if (!lineTable || !totalsWrap || !totalsTable) {
                document.body.classList.remove('print-totals-new-page');
                return;
            }
            var pageH = printablePageHeightPx();
            if (pageH < 200) pageH = a4HeightPx();

            var headerSharesPage = parentHeaderOnTotalsPage(parentheadertable, totalsWrap, pageH);
            if (!headerSharesPage) {
                document.body.classList.add('print-totals-new-page');
            } else {
                document.body.classList.remove('print-totals-new-page');
            }
        }
        /** Grow tbody spacer row(s) by the slack height so blank space moves into the spacer (between lines and totals), shrinking empty area below content. Split evenly if multiple .spacer-row. */
        function fillSpacerRows() {
            var table = document.getElementById('rent-bill-line-items-table');
            var spacers = table ? table.querySelectorAll('tbody tr.spacer-row') : [];
            if (!spacers.length) return;
            for (var s = 0; s < spacers.length; s++) {
                var row = spacers[s];
                row.style.height = '';
                var cells = row.querySelectorAll('td');
                for (var i = 0; i < cells.length; i++) {
                    cells[i].style.height = '';
                }
            }
            var vh = window.innerHeight || document.documentElement.clientHeight || 0;
            var target = vh > 400 ? vh : a4HeightPx();
            var sh = document.body.scrollHeight || document.documentElement.scrollHeight || 0;
            var extra = target - sh - 1;
            if (extra <= 2) return;
            var n = spacers.length;
            var per = Math.floor(extra / n);
            var rem = extra % n;
            for (var k = 0; k < n; k++) {
                var r = spacers[k];
                var add = per + (k < rem ? 1 : 0);
                var base = r.offsetHeight || 4;
                var h = base + add;
                r.style.height = h + 'px';
                var cs = r.querySelectorAll('td');
                for (var j = 0; j < cs.length; j++) {
                    cs[j].style.height = h + 'px';
                }
            }
        }
        function schedule() {
            fillSpacerRows();
            updateTotalsRepeatHeader();
            setTimeout(function () { fillSpacerRows(); updateTotalsRepeatHeader(); }, 120);
            setTimeout(function () { fillSpacerRows(); updateTotalsRepeatHeader(); }, 450);
        }
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', schedule);
        } else {
            schedule();
        }
        window.addEventListener('load', function () { fillSpacerRows(); updateTotalsRepeatHeader(); });
        window.addEventListener('resize', function () { fillSpacerRows(); updateTotalsRepeatHeader(); });
        window.addEventListener('beforeprint', function () {
            fillSpacerRows();
            requestAnimationFrame(function () {
                requestAnimationFrame(updateTotalsRepeatHeader);
            });
        });
        window.addEventListener('afterprint', function () {
            document.body.classList.remove('print-totals-new-page');
        });
    })();
</script>
@* NReco/wkhtmltopdf: CustomWkHtmlArgs += " --javascript-delay 500" so fillSpacerRows runs after layout/images. *@
</html>
