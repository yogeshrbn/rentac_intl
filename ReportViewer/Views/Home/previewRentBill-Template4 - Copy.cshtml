<body>

  
    <table class="table-container">
        <colgroup>
            <col style="width: 301px;">
            <col style="width: 80px;">
            <col style="width: 70px;">

            <col style="width: 40px;">
            <col style="width: 50px;">
            <col style="width: 60px;">
            <col style="width: 80px;">
        </colgroup>
        <thead>
            <tr>

                <td colspan="7" style="text-align: center; font-size: 24px !important;"> @invoiceTitle </td>

            </tr>
            <tr>
                <td colspan="7" style="border-bottom:none;">
                    <table style="width:100%;margin:0px;" class="headertable" cellpadding="0" cellspacing="0">

                        <tr>
                            <td style="width:70%;border:0px;">
                                <img src="@imagepath" style="max-width:100px" />
                            </td>
                            <td>
                                <table style="width:100%;">
                                    <tr>
                                        <td><span class="page"></span></td>
                                    </tr>
                                    <tr>
                                        <td style="text-align: right; font-size: 12pt !important; "><strong>PAN: </strong>@firstRow["CompanyPAN"]</td>
                                    </tr>
                                    <tr>
                                        <td style="text-align: right; font-size: 12pt !important;"><strong>GSTIN: </strong>@firstRow["CompanyGST"]  </td>
                                    </tr>
                                    @if (BillingConfigViewHelper.ShouldShowContactField(showMSMENumberMode, firstRow["MSMENumber"]))
                                    {
                                        <tr>
                                            <td style="text-align: right; font-size: 12pt !important;"><strong>MSME Number: </strong>@firstRow["MSMENumber"]  </td>
                                        </tr>
                                    }
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2">
                                <table style="width: 100%; border: none;">
                                    <tr>
                                        <td style="width:80%;border:none;">
                                            <ul style="list-style:none;padding-left:0px;font-size:12pt !important;">
                                                <li><strong style="font-size:18pt;"> @firstRow["Company"]</strong></li>
                                                <li class="compAddr">@firstRow["CompanyAddress1"] @firstRow["CompanyAddress2"]</li>
                                                <li class="compAddr">@firstRow["CompanyCity"] (@firstRow["CompanyStateName"]) Pin:- @firstRow["CompanyZipCode"]</li>

                                                @if (BillingConfigViewHelper.ShouldShowContactField(showCompanyPhoneMode, firstRow["CompanyPhone"])
                                                    || BillingConfigViewHelper.ShouldShowContactField(showCompanyEmailMode, firstRow["CompanyEmail"]))
