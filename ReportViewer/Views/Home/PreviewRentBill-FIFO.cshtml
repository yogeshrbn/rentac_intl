<body>

    @*<header>Confidential Report (continued)</header>*@
    <table style="width:100%;margin:0px;" class="headertable" cellpadding="0" cellspacing="0">

        <tr>
            <td style="width:70%;">
                <img src="@imagepath" style="max-width:140px" />
            </td>
            <td>
                <table style="width:100%;">

                    <tr>
                        <td style="text-align: right; font-size: 14px !important; "><strong>PAN: </strong>@firstRow["CompanyPAN"]</td>
                    </tr>
                    <tr>
                        <td style="text-align: right; font-size: 14px !important;"><strong>GSTIN: </strong>@firstRow["CompanyGST"]  </td>
                    </tr>
                    @if (BillingConfigViewHelper.ShouldShowContactField(showMSMENumberMode, firstRow["MSMENumber"]))
                    {
                        <tr>
                            <td style="text-align: right; font-size: 14px !important;"><strong>MSME Number: </strong>@firstRow["MSMENumber"]  </td>
                        </tr>
                    }
                </table>
            </td>
        </tr>
        <tr>
            <td colspan="2">
                <table style="width:100%;">
                    <tr>
                        <td style="width:80%">
                            <ul style="list-style:none;padding-left:0px;font-size:14px !important;">
                                <li><strong style="font-size:16pt;" class="companyName"> @firstRow["Company"]</strong></li>
                                <li class="compAddr">@firstRow["CompanyAddress1"] @firstRow["CompanyAddress2"]</li>
                                <li class="compAddr">@firstRow["CompanyCity"] (@firstRow["CompanyStateName"]) Pin:- @firstRow["CompanyZipCode"]</li>

                                @if (BillingConfigViewHelper.ShouldShowContactField(showCompanyPhoneMode, firstRow["CompanyPhone"])
                                    || BillingConfigViewHelper.ShouldShowContactField(showCompanyEmailMode, firstRow["CompanyEmail"]))
                                {
                                    <li class="compAddr">
                                        @if (BillingConfigViewHelper.ShouldShowContactField(showCompanyPhoneMode, firstRow["CompanyPhone"]))
                                        {
                                            <span> Mobile: @firstRow["CompanyPhone"]@(BillingConfigViewHelper.ShouldShowContactField(showCompanyEmailMode, firstRow["CompanyEmail"]) ? "," : "")</span>
                                        }
                                        @if (BillingConfigViewHelper.ShouldShowContactField(showCompanyEmailMode, firstRow["CompanyEmail"]))
                                        {
                                            <span> Email: @firstRow["CompanyEmail"]</span>
                                        }
                                    </li>
                                }
                                @if (BillingConfigViewHelper.ShouldShowContactField(showCompanyWebsiteMode, firstRow["CompanyWebsite"]))
                                {
                                    <li>Web: @firstRow["CompanyWebsite"]</li>
                                }
                            </ul>
                        </td>
                        <td style="text-align: right; font-size: 20px !important; font-weight: 600"> @invoiceTitle </td>
                    </tr>
                </table>
            </td>
            @*<td style="padding-left:0px;">
                    <ul style="list-style:none;padding-left:0px;">
                        <li><strong style="font-size:14px;" class="companyName"> @firstRow["Company"]</strong></li>
                        <li class="compAddr">@firstRow["CompanyAddress1"] @firstRow["CompanyAddress2"]</li>
                        <li class="compAddr">@firstRow["CompanyCity"] (@firstRow["CompanyStateName"]) Pin:- @firstRow["CompanyZipCode"]</li>
                        <li class="compAddr">Mobile: @firstRow["CompanyPhone"], Email: @firstRow["CompanyEmail"]</li>

                    </ul>

                </td>
                <td style="text-align:right;font-size:20px;font-weight:600">TAX INVOICE</td>*@
        </tr>
        <tr>
            <td colspan="2">
                <table style="width:100%">
                    <tr>
                        <td class="compAddr" style="font-size: 12pt !important; font-weight: bold ">@billPeriodText: @BAL.Objects.Utils.FormatDate(minDate) -  @BAL.Objects.Utils.FormatDate(lastDate)</td>
                        <td class="compAddr" style="font-size: 12pt !important; font-weight: bold; text-align: right;">  Invoice No:  @firstRow["InvoiceNumber"]  Date:   @BAL.Objects.Utils.FormatDate(@firstRow["InvoiceDate"])</td>
                    </tr>
                </table>
            </td>
        </tr>
        <tr>
            <td colspan="2">
                <table width="100%" style="border-collapse: collapse; margin: 0px;">
                    <tr>
                        <td style="vertical-align: top; text-align: left; border: solid 1px; padding: 3px;
                            font-weight: normal; width: 485px !important; border-bottom: none;">
                            <label style="font-weight:bold;font-size:13pt;">Bill To</label>
                            <div>
                                @if (Convert.ToInt16(firstRow["BillFromSiteAddress"]) == 1)
                                {
                                    <table style="width:100%;" class="address-table">
                                        <tr><td class="addresstd" style="font-size:13pt !important"><strong>@firstRow["ClientBillToName"]</strong></td></tr>
                                        <tr>
                                            <td class="addresstd">
                                                @firstRow["SiteProject"] @firstRow["SiteAddress"]  @firstRow["SiteAddress2"]
                                                @firstRow["City"] (@firstRow["SiteState"])@if (BillingConfigViewHelper.ShouldShowContactField(showClientPinMode, firstRow["SiteZipCode"]))
                                                {<text> Pin:- @firstRow["SiteZipCode"] </text>}
                                            </td>
                                        </tr>
                                        @*<tr>
                                                <td class="addresstd">

                                                </td>
                                            </tr>*@
                                        @if (!String.IsNullOrEmpty(firstRow["SiteGST"]))
                                        {
                                            <tr><td class="addresstd"> GSTIN: @firstRow["SiteGST"]</td></tr>
                                        }
                                        @if (BillingConfigViewHelper.ShouldShowContactField(showClientMobileMode, firstRow["ClientPhone"]) || BillingConfigViewHelper.ShouldShowContactField(showClientEmailMode, firstRow["ClientEmail"]))
                                        {
                                            <tr>
                                                <td class="addresstd">
                                                    @if (BillingConfigViewHelper.ShouldShowContactField(showClientMobileMode, firstRow["ClientPhone"]))
                                                    {
                                                        <span> Mobile: @firstRow["ClientPhone"];</span>
                                                    }
                                                    @if (BillingConfigViewHelper.ShouldShowContactField(showClientEmailMode, firstRow["ClientEmail"]))
                                                    {
                                                        <span> Email: @firstRow["ClientEmail"];</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </table>
                                }
                                else
                                {
                                    <table style="width:100%;" class="address-table">
                                        <tr><td class="addresstd"><strong>@firstRow["ClientBillToName"]</strong></td></tr>
                                        <tr>
                                            <td class="addresstd">
                                                @firstRow["ClientAddress1"] @firstRow["ClientAddress2"]
                                                @firstRow["ClientCity"] (@firstRow["ClientStateName"])@if (BillingConfigViewHelper.ShouldShowContactField(showClientPinMode, firstRow["ClientZipCode"]))
                                                {<text> Pin:- @firstRow["ClientZipCode"] </text>}
                                            </td>
                                        </tr>
                                        @*<tr>
                                                <td class="addresstd">

                                                </td>
                                            </tr>*@
                                        <tr><td class="addresstd" style=""> GSTIN: @firstRow["ClientGST"]</td></tr>
                                        @if (BillingConfigViewHelper.ShouldShowContactField(showClientMobileMode, firstRow["ClientPhone"]) || BillingConfigViewHelper.ShouldShowContactField(showClientEmailMode, firstRow["ClientEmail"]))
                                        {
                                            <tr>
                                                <td class="addresstd">
                                                    @if (BillingConfigViewHelper.ShouldShowContactField(showClientMobileMode, firstRow["ClientPhone"]))
                                                    {
                                                        <span> Mobile: @firstRow["ClientPhone"];</span>
                                                    }
                                                    @if (BillingConfigViewHelper.ShouldShowContactField(showClientEmailMode, firstRow["ClientEmail"]))
                                                    {
                                                        <span> Email: @firstRow["ClientEmail"];</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </table>
                                }

                            </div>
                            @if (BillingConfigViewHelper.ShouldShowStringField(showPONumberMode, firstRow["billPONumber"]))

                            {
                                <strong>Customer PO Number:</strong> @firstRow["billPONumber"]
                                <strong>| PO Date:</strong> @BAL.Objects.Utils.CheckDateAndReturnDefault(Convert.ToString(firstRow["billPODate"]), "")
                            }
                            else if (!String.IsNullOrEmpty(Convert.ToString(firstRow["PONumbers"])))
                            {
                                <div style="font-size:10pt;margin-top:5px;width:100%">
                                    <strong>PO Number:</strong> @firstRow["PONumbers"]
                                </div>
                            }
                        </td>
                        <td style="text-align: left; border: solid 1px; font-weight: normal; padding:3px; border-bottom: none;vertical-align:top;">
                            <label style="font-weight: bold; font-size: 13pt;">Ship To</label>
                            <table style="width:100%">
                                <tr><td class="addresstd"><strong>@firstRow["ClientBillToName"]</strong></td></tr>
                                <tr><td class="addresstd">@firstRow["SiteProject"]</td></tr>
                                <tr>
                                    <td class="addresstd">
                                        @firstRow["SiteAddress"] @firstRow["SiteAddress2"]
                                        @firstRow["City"] @firstRow["SiteState"]@if (BillingConfigViewHelper.ShouldShowContactField(showClientPinMode, firstRow["SiteZipCode"]))
                                        {<text> Pin:-  @firstRow["SiteZipCode"]  </text>}
                                    </td>
                                </tr>
                                @*<tr>
                                        <td class="addresstd">

                                        </td>
                                    </tr>*@
                                <tr>
                                    <td class="addresstd">
                                        @if (!String.IsNullOrEmpty(Convert.ToString(firstRow["ContactPerson"])))
                                        {
                                            <span> Contact: @firstRow["ContactPerson"];</span>
                                        }
                                        @if (!String.IsNullOrEmpty(Convert.ToString(firstRow["ContactPersonPhone"])))
                                        {
                                            <span> Mob: @firstRow["ContactPersonPhone"];</span>
                                        }
                                    </td>
                                </tr>
                                @if (ViewBag.ShowChallans == true && !String.IsNullOrEmpty(challans))
                                {
                                    <tr><td class="addresstd" style="border-top: solid 1px;"><label style="font-weight:bold;font-size:10pt;">Challans</label></td></tr>
                                    <tr>
                                        <td style="font-size:10pt !important;">
                                            @challans
                                        </td>
                                    </tr>
                                }
                            </table>
                        </td>
                    </tr>
                </table>
            </td>

        </tr>
    </table>
    <div class="page">
        <div class="content">

            <table class="table-container">
                <colgroup>
                    <col style="width: 315px;">
                    @*<col style="width: 80px;">*@
                    <col style="width: 70px;">

                    @*<col style="width: 40px;">*@
                    <col style="width: 50px;">
                    <col style="width: 60px;">
                    <col style="width: 80px;">
                </colgroup>
                <thead>
                    <tr>
                        <th class="table-cell" style="border-right: none;">Description</th>
                        @*<th class="table-cell" style="width: 80px; border-left: none; ">
                            @billPeriodText&nbsp;
                            </th>*@
                        <th class="table-cell" style="width:70px;">SAC Code</th>
                        @*<th class="table-cell" style="width:40px;">Days</th>*@
                        <th class="table-cell" style="width:50px;">Qty</th>
                        <th class="table-cell" style="width:60px;">Rate</th>
                        <th class="table-cell" style="width:80px;text-align:right;">Amount</th>
                    </tr>
                </thead>
                <tbody class="table-body">
                    @*<tr class="table-row">
                            <td class="table-cell" style="width:70mm;border-right:none;">Description</td>
                            <td class="table-cell" style="width: 0.5in !important; border-left: none;">@billPeriodText</td>
                            <td class="table-cell" style="width:70px;">SAC Code</td>
                            <td class="table-cell" style="width:40px;">Days</td>
                            <td class="table-cell" style="width:50px;">Number</td>
                            <td class="table-cell" style="width:60px;">Rate</td>
                            <td class="table-cell" style="width:80px;">Amount</td>
                        </tr>*@
                    @{
                        foreach (var g in ViewBag.UniqueItems)
                        {

                            string borderCss = "firstRow";
                            string item = "";
                            int x = 0;
                            bool itemPrinted = false;
                            foreach (var row in data.Tables[0].Select("ProductId = " + g.ToString()))
                            {
                                if (x == 0)
                                {
                                    item = Convert.ToString(row["Item"]);
                                }
                                else
                                {
                                    if (itemPrinted == true)
                                    {
                                        // item = "";
                                    }
                                }
                                x++;
                                if (Convert.ToDouble(row["SubTotal"]) == 0)
                                {
                                    if (ViewBag.hideZeroAmountItem)
                                    {
                                        continue;
                                    }
                                }
                                itemPrinted = true;
                                var variance = (Convert.ToInt32(@row["CB"]) - Convert.ToInt32(@row["Quantity"]));
                                <tr class="table-row line-items">
                                    <td class="@borderCss noborder_b" style="padding: 5px 3px; border-left: solid 1px;">
                                        <div style="font-size: 11pt !important;font-weight:bold; ">
                                            @item
                                        </div>
                                        <div style="font-size:10pt;margin-left:5px;margin-top:0px;display:inline-block">

                                            @*@if (variance != 0 || row["Days"] == 1)
                                                {*@
                                            <span style="width:50%;">
                                                Period @row["Period"]
                                            </span>
                                            @*}*@
                                            @if (Convert.ToInt16(row["rateCalcType"]) == 2 && row["Days"] > 1)
                                            {
                                                <span style="margin-left:10px;">@row["Days"]-Days@@ @row["MasterRentRate"]/-PM</span>
                                            }
                                        </div>
                                    </td>

                                    @*<td class="@borderCss noborder_bl text-center">
                                        @row["Period"]
                                        </td>*@
                                    <td class="@borderCss noborder_bl text-center;" style="border-left: solid 1px; text-align: center; vertical-align: middle">
                                        @if (item != "")
                                        {
                                            @row["SACCode"]
                                        }


                                    </td>
                                    @*<td class="border noborder_bl table-cell text-center" style="vertical-align:middle">

                                            @if (showDetailedDayCalculation && row["rateCalcType"] == 2 && @row["Days"] == 1)
                                            {

                                                @row["DaysInMonth"]

                                            }
                                            else
                                            {
                                                @row["Days"]
                                            }
                                        </td>*@
                                    <td class="border table-cell text-center" style="vertical-align:middle">
                                        @row["Quantity"] @Convert.ToString(row["UnitName"]).ToUpper()
                                    </td>
                                    <td class="table-cell text-center" style="vertical-align:middle">

                                        @(Convert.ToDecimal(row["Rate"]) * Convert.ToInt32(@row["Days"]))
                                        @*.ToString("N", System.Globalization.CultureInfo.InvariantCulture)*@

                                    </td>
                                    <td class="table-cell text-right" style="vertical-align:middle">

                                        @row["SubTotal"].ToString("N", System.Globalization.CultureInfo.InvariantCulture)

                                    </td>
                                </tr>


                                borderCss = "";

                            }


                            if (getGroupItemsOnPrint)
                            {
                                System.Data.DataRow frow = data.Tables[0].Select("ProductId = " + g.ToString())[0];
                                // Using LINQ's Sum method
                                decimal totalSubtotal = data.Tables[0].Compute("Sum(SubTotal)", "ProductId =  " + g.ToString());
                                decimal cb = data.Tables[0].Compute("Sum(CB)", "ProductId =  " + g.ToString());


                                <tr class="table-row">
                                    <td colspan="1" class="border noborder_bl table-cell text-center" style="border-top:none;"></td>
                                    <td class="border noborder_bl table-cell text-right fw-bold" colspan="3"><strong>Total</strong></td>
                                    @*<td class="border noborder_bl table-cell text-center"></td>

                                        <td class="border table-cell text-center" style="border-left:solid 1px;"></td>*@
                                    @*<td class="table-cell text-center"></td>*@
                                    <td class="table-cell text-right"><strong>@totalSubtotal</strong></td>

                                </tr>
                            }

                        }

                    }

                    <tr class="table-row spacer-row">
                        <td class="table-cell" colspan="1">&nbsp;</td>
                        <td class="table-cell">&nbsp;</td>
                        @*<td class="table-cell">&nbsp;</td>*@
                        <td class="table-cell">&nbsp;</td>
                        <td class="table-cell">&nbsp;</td>
                        <td class="table-cell">&nbsp;</td>
                    </tr>
                    <tr class="table-row" style=" page-break-inside: avoid;">
                        <td colspan="2" rowspan="@rowsToSpanAtBottom" class="border"
                            style="text-align:left; vertical-align:top;padding-top:20px;padding-left:8px;">
                            In Words: @BAL.Objects.Utils.AmountToWords(Convert.ToDecimal(total))
                            <br /> <br />
                            @if (ViewBag.LastBill != null && Convert.ToInt16(firstRow["printLastBillDetails"]) == 1)
                            {
                                <div>
                                    <ul style="list-style:none;">
                                        <li>  <u>Last Bill Details:</u></li>
                                        <li style="padding-top:12px;">Invoice#: @ViewBag.LastBill.InvoiceNumber | Date: @BAL.Objects.Utils.FormatDate(ViewBag.LastBill.InvoiceDate) | Amount: @Math.Round(ViewBag.LastBill.Total, MidpointRounding.AwayFromZero)   </li>
                                    </ul>
                                </div>
                                <br />
                            }
                            @if (ViewBag.PrintBalanceMaterial == true)
                            {
                                <ul style="list-style:none;">
                                    <li>
                                        <u>Balance Qty:</u>
                                    </li>

                                    @foreach (var b in balanceTable)
                                    {

                                        <li>@b.Product : @b.Quantity</li>


                                    }
                                </ul>
                            }
                            @{
                                <div style="width:100%;background-color:red;">
                                    <div style="width:60%;float:left">
                                        @if (ViewBag.PrintBankDetails)
                                        {
                                            <ul style="list-style:none;">
                                                <li><b>Bank Details</b></li>
                                                <li>Bank ACC. No: @ViewBag.CompanyInfo.BankAccNumber</li>
                                                <li>Bank: @ViewBag.CompanyInfo.BankName</li>
                                                <li>Branch: @ViewBag.CompanyInfo.BankBranch</li>
                                                <li>IFSC COde: @ViewBag.CompanyInfo.IFSCCode</li>
                                            </ul>
                                        }
                                    </div>

                                    @if (ViewBag.PrintQrCode)
                                    {
                                        <div style="width:40%;float:right;border:none;">
                                            @if (!String.IsNullOrEmpty(Convert.ToString(firstRow["QrCode"])))
                                            {
                                                <img src="@firstRow["QrCode"]" style="width:120px;height:120px;border:none" />
                                            }
                                        </div>
                                    }

                                </div>
                            }
                        </td>
                        <td colspan="2" class="table-cell border noborder_bl" style="vertical-align:top">Sub Total</td>
                        <td class="table-cell border noborder_bl text-right" style="vertical-align:top">@subTotal.ToString("N", System.Globalization.CultureInfo.InvariantCulture)</td>
                    </tr>

                    @{
                        if (firstRow["Freight"] > 0)
                        {

                            <tr class="table-row">

                                <td colspan="2" class="table-cell border noborder_bl">Freight</td>
                                <td class="table-cell border noborder_bl text-right">@firstRow["Freight"].ToString("N", System.Globalization.CultureInfo.InvariantCulture)</td>
                            </tr>

                        }
                    }
                    @{
                        if (breakageCharges > 0)
                        {
                            <tr class="table-row">

                                <td colspan="2" class="table-cell border noborder_bl">Breakage</td>
                                <td class="table-cell border noborder_bl text-right">@breakageCharges.ToString("N", System.Globalization.CultureInfo.InvariantCulture)</td>
                            </tr>
                        }
                    }

                    @{
                        if (lossCharges > 0)
                        {
                            <tr class="table-row">

                                <td colspan="2" class="table-cell border noborder_bl">Loss Charges</td>
                                <td class="table-cell border noborder_bl text-right">@lossCharges.ToString("N", System.Globalization.CultureInfo.InvariantCulture)</td>
                            </tr>
                        }
                    }

                    @{
                        foreach (var charge in charges.Rows)
                        {
                            <tr class="table-row">

                                <td colspan="2" class="table-cell border noborder_bl">@charge["Name"] </td>
                                <td class="table-cell border noborder_bl text-right">@charge["Amount"].ToString("N", System.Globalization.CultureInfo.InvariantCulture)</td>
                            </tr>
                        }
                    }
                    @if (IGST > 0)
                    {
                        <tr class="table-row">

                            <td colspan="2" class="table-cell border noborder_bl">IGST (@Convert.ToInt16(firstRow["IGSTRate"])%)</td>
                            <td class="table-cell border noborder_bl text-right">@IGST.ToString("N", System.Globalization.CultureInfo.InvariantCulture)</td>

                        </tr>
                    }
                    @if (CGST > 0)
                    {
                        <tr class="table-row">

                            <td colspan="2" class="table-cell border noborder_bl">CGST  (@Convert.ToInt16(firstRow["CGSTRate"])%)</td>
                            <td class="table-cell border noborder_bl text-right">@CGST.ToString("N", System.Globalization.CultureInfo.InvariantCulture)</td>

                        </tr>
                    }
                    @if (SGST > 0)
                    {
                        <tr class="table-row">

                            <td colspan="2" class="table-cell border noborder_bl">SGST  (@Convert.ToInt16(firstRow["SGSTRate"])%)</td>
                            <td class="table-cell border noborder_bl text-right">@SGST.ToString("N", System.Globalization.CultureInfo.InvariantCulture)</td>

                        </tr>
                    }
                    @if (firstRow["discount"] > 0)
                    {
                        <tr class="table-row">
                            <td colspan="2" class="table-cell border noborder_bl">Discount</td>
                            <td class="table-cell border noborder_bl text-right">@firstRow["discount"].ToString("N", System.Globalization.CultureInfo.InvariantCulture) </td>
                        </tr>
                    }
                    @if (firstRow["lossDiscount"] > 0)
                    {
                        <tr class="table-row">
                            <td colspan="2" class="table-cell border noborder_bl">Loss Discount</td>
                            <td class="table-cell border noborder_bl text-right">@firstRow["lossDiscount"].ToString("N", System.Globalization.CultureInfo.InvariantCulture) </td>
                        </tr>
                    }
                    @if (firstRow["breakageDiscount"] > 0)
                    {
                        <tr class="table-row">
                            <td colspan="2" class="table-cell border noborder_bl">Breakage Discount</td>
                            <td class="table-cell border noborder_bl text-right">@firstRow["breakageDiscount"].ToString("N", System.Globalization.CultureInfo.InvariantCulture) </td>
                        </tr>
                    }
                    @if (roundOf != 0)
                    {
                        <tr class="table-row">
                            <td colspan="2" class="table-cell border noborder_bl">Round Off</td>
                            <td class="table-cell border noborder_bl text-right">@roundOf.ToString("N", System.Globalization.CultureInfo.InvariantCulture)</td>
                        </tr>
                    }
                    <tr class="table-row">

                        <td colspan="2" class="table-cell noborder_bl" style="border-bottom:solid 1px">Total</td>
                        <td class="table-cell  text-right" style="border-bottom:solid 1px">@total.ToString("N", System.Globalization.CultureInfo.InvariantCulture)</td>
                    </tr>
                    @{
                        if (firstRow["SignedQrCode"] != DBNull.Value)
                        {
                            <tr>
                                <td colspan="5" class="border noborder_b" style="text-align:center;padding:12px;border-bottom:none;">
                                    <table>
                                        <tr>
                                            <td>
                                                <img src="@firstRow["SingedQrCode"]" style="width:120px;height:120px;" />
                                            </td>
                                        </tr>
                                    </table>

                                </td>
                            </tr>
                        }


                    }
                    <tr class="table-row">
                        <td colspan="5" style="border-left:solid 1px; border-right:solid 1px;border-bottom:solid 1px;">
                            <table style="width:100%;border-top:none;">
                                <tr>

                                    <td class="text-right" colspan="2">
                                        <span style="font-size:13pt;font-weight:bold;"> For:- @firstRow["Company"]</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td rowspan="2" style="vertical-align:top;">
                                        <div style="width:80%;font-size:9pt !important">  @Html.Raw(firstRow["Tnc"])</div>
                                    </td>
                                </tr>
                                <tr>

                                    <td style="text-align:right;width:150px;">  <img src="@signature" style="max-width:150px;max-height:50px;" /></td>
                                </tr>
                                <tr>
                                    <td style="padding-top:12px;" class="text-right" colspan="2">
                                        <span style="font-size:14pt;font-weight:bold;">Authorized Signatory</span>
                                    </td>
                                </tr>

                            </table>
                        </td>
                    </tr>

                </tbody>

            </table>
            @{
                if (excessQty != null && excessQty.Length > 0 && ViewBag.PrintExcessQty)
                {
                    <div style="width:100%;page-break-before:auto">
                        <h3>Axcess Qty</h3>
                        <table border="0" style="width:100%" cellspacing="0">
                            <tr>
                                <td class="header_table" style="border: solid 1px; border-right: 0px;">Description</td>
                                <td class="header_table text-right" style="border: solid 1px; width: 100px;">Quantity</td>

                            </tr>
                            @foreach (var row in excessQty)
                            {
                                <tr>
                                    <td style="border: solid 1px; border-top: none; border-right: none;">@row["Item"]</td>
                                    <td class="text-right" style="border: solid 1px; border-top: none;">@row["ExcessQty"]</td>
                                </tr>
                            }
                        </table>
                    </div>
                }
            }
            @{
                if (lossItems != null && lossItems.Rows.Count > 0)
                {
                    <div style="width:100%;page-break-before:auto">
                        <h3>Loss Items</h3>
                        <table border="0" style="width:100%" cellspacing="0">
                            <tr>


                                <td class="header_table" style="border: solid 1px; border-right: 0px;">Description</td>
                                <td class="header_table text-right" style="border: solid 1px; width: 100px; border-right: 0px;">Quantity</td>
                                <td class="header_table text-right" style="border: solid 1px; width: 100px; border-right: 0px;">Rate</td>
                                <td class="header_table text-right" style="border: solid 1px; width: 100px; ">Amount</td>
                            </tr>
                            @foreach (var row in lossItems.Rows)
                            {
                                <tr>
                                    <td style="border: solid 1px; border-top: none; border-right: none;">@row["Item"]</td>
                                    <td style="border: solid 1px; border-top: none; border-right: none;">@row["Quantity"]</td>

                                    <td class="text-right" style="border: solid 1px; border-top: none; border-right: none; ">@row["Rate"]</td>
                                    <td class="text-right" style="border: solid 1px; border-top: none;">@row["Amount"]</td>
                                </tr>
                            }
                        </table>
                    </div>
                }
            }
            @{
                if (breakageItems != null && breakageItems.Rows.Count > 0)
                {

                    <div class="breakage" style="width:100%;">
                        <h3>Breakage Items</h3>
                        <table border="0" style="width:100%" cellspacing="0">
                            <tr>
                                <td class="header_table" style="border: solid 1px; border-right: 0px;">Description</td>
                                <td class="header_table text-center" style="border: solid 1px; width: 100px; border-right: 0px;">Quantity</td>

                                @*<td class="header_table text-right" style="border: solid 1px; width: 100px; border-right: 0px;">Rate</td>
                                    <td class="header_table text-right" style="border: solid 1px; width: 100px; ">Amount</td>*@
                            </tr>
                            @foreach (var row in breakageItems.Rows)
                            {
                                <tr>
                                    <td style="border: solid 1px; border-top: none; border-right: none;">@row["Item"]</td>
                                    <td class="text-center" style="border: solid 1px; border-top: none; border-right: none;">@row["Quantity"]</td>
                                    @* <td class="text-right" style="border: solid 1px; border-top: none; border-right: none; ">@row["Rate"]</td>
                                        <td class="text-right" style="border: solid 1px; border-top: none;">@row["Amount"]</td>*@
                                </tr>
                            }
                        </table>
                    </div>
                }
            }
            @if (printDamageComponentsDetails && breakageDamageDetailsList != null && breakageDamageDetailsList.Count > 0)
            {
                <div class="breakage-damage-components" style="width:100%;page-break-before:auto;margin-top:16px;">
                    <h4>Damage components</h4>
                    <table border="0" style="width:100%" cellspacing="0">
                        <tr>
                            <td class="header_table" style="border: solid 1px; border-right: 0px;">item</td>
                            <td class="header_table" style="border: solid 1px; border-right: 0px;">Challan#</td>
                            <td class="header_table" style="border: solid 1px; border-right: 0px;">Component</td>
                            <td class="header_table text-center" style="border: solid 1px; width: 72px; border-right: 0px;">Qty</td>
                            <td class="header_table text-right" style="border: solid 1px; width: 88px; border-right: 0px;">Rate</td>
                            <td class="header_table text-right" style="border: solid 1px; width: 96px; border-right: 0px;">Amount</td>
                            <td class="header_table text-center" style="border: solid 1px; width: 96px;">Received</td>
                        </tr>
                        @foreach (var d in breakageDamageDetailsList)
                        {
                            <tr>
                                <td style="border: solid 1px; border-top: none; border-right: none;">@d.ParentItem</td>
                                <td style="border: solid 1px; border-top: none; border-right: none;">@d.GRN</td>
                                <td style="border: solid 1px; border-top: none; border-right: none;">@d.ComponentName</td>
                                <td class="text-center" style="border: solid 1px; border-top: none; border-right: none;">@d.Quantity</td>
                                <td class="text-right" style="border: solid 1px; border-top: none; border-right: none;">@d.Rate</td>
                                <td class="text-right" style="border: solid 1px; border-top: none; border-right: none;">@d.Cost</td>
                                <td class="text-center" style="border: solid 1px; border-top: none;">@(d.ReceivingDate.HasValue ? BAL.Objects.Utils.FormatDate(d.ReceivingDate.Value) : "")</td>
                            </tr>
                        }
                    </table>
                </div>
            }
        </div>
    </div>

</body>
</html>

